#!/bin/bash
# Hook pre-commit do Spellbook-OS / ~/.config/zsh
#
# Politica (desde 2026-06-01): APLICA as correções e INFORMA o que mudou, em vez
# de bloquear. Remove emojis (preservando os glyphs canonicos da fonte unica) e
# corrige acentuação PT-BR (--fix) nos arquivos staged, re-adiciona o que mudou e
# segue. NAO mexe em identidade/secrets aqui (isso fica no `ga`/sanitizer); o
# pre-push continua como ultima linha de defesa -- as proteções de rede permanecem.
#
# Instalação (uma vez): git config core.hooksPath .githooks
# Pular em commit urgente: SKIP_HOOKS=1 git commit -m "..."

set -e

if [[ "$SKIP_HOOKS" == "1" ]]; then
    echo "[pre-commit] pulado (SKIP_HOOKS=1)"
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(py|zsh|sh|md)$' || true)
if [[ -z "$STAGED_FILES" ]]; then
    exit 0
fi

STAGED_ARR=()
while IFS= read -r f; do
    [[ -n "$f" && -f "$f" ]] && STAGED_ARR+=("$f")
done <<< "$STAGED_FILES"
[[ ${#STAGED_ARR[@]} -eq 0 ]] && exit 0

# 1. Emoji: remove aplicando (preserva os 11 glyphs canonicos via fonte unica).
#    Os glyphs vivem em U+25xx/U+219x, fora do range de emoji -- dupla garantia.
echo "[pre-commit] Removendo emojis (preserva glyphs canonicos)..."
python3 - "${STAGED_ARR[@]}" <<'PY' || true
import sys, re
sys.path.insert(0, "scripts")
try:
    from glyphs_canonicos import ALLOWED_GLYPHS
except Exception:
    ALLOWED_GLYPHS = frozenset()
EMOJI_RE = re.compile(r"[\U0001F300-\U0001FAFF\U00002600-\U000027BF\U0001F900-\U0001F9FF]")
for path in sys.argv[1:]:
    try:
        s = open(path, encoding="utf-8").read()
    except Exception:
        continue
    c = [0]
    def repl(m):
        if m.group() in ALLOWED_GLYPHS:
            return m.group()
        c[0] += 1
        return ""
    new = EMOJI_RE.sub(repl, s)
    if new != s:
        open(path, "w", encoding="utf-8").write(new)
        print(f"  emoji removido: {path} ({c[0]})")
PY

# 2. Acentuação PT-BR: aplica --fix e informa (corrigidos + os que precisam de revisão)
if [[ -f "scripts/validar-acentuacao.py" ]]; then
    echo "[pre-commit] Corrigindo acentuação PT-BR..."
    python3 scripts/validar-acentuacao.py --fix --paths "${STAGED_ARR[@]}" || true
fi

# 3. Re-adiciona ao stage o que foi corrigido (mantém o commit consistente)
git add "${STAGED_ARR[@]}" 2>/dev/null || true

# 4. Nao bloqueia (Caminho A). Ressalva: o dicionário de acentuação é parcial --
#    palavras fora dele nao sao detectadas; o pre-push segue como rede final.
echo "[pre-commit] OK -- correções aplicadas e re-adicionadas ao commit."
exit 0
