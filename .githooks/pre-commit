#!/bin/bash
# Hook Universal Pre-Commit - Auto-fix com relatorio
# Camada 1 de defesa: auto-fix em arquivos staged
# Instalado via aplicar_hooks_globais()

# INFRA-HOOK-LOCAL-WIRING-01 (sprint 199, 2026-05-22): delega para hook
# local do Nyx-Code quando o commit esta dentro daquele repo. Fecha
# defense-in-depth do invariante #14 (anti-sanitizer guard, sprint 196).
# Outros projetos do usuario passam direto (zero impacto).
_nyx_root="/home/andrefarias/Desenvolvimento/Nyx-Code"
_repo_root_wiring=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
if [ "$_repo_root_wiring" = "$_nyx_root" ]; then
    _local_hook="$_nyx_root/scripts/hooks/pre-commit"
    if [ -x "$_local_hook" ]; then
        "$_local_hook" || exit $?
    fi
fi

# AUDIT-PRECOMMIT-INERTE-REATIVAR (sprint do protocolo-ouroboros, 2026-06-11,
# autorizado pelo dono): delega para o framework pre-commit do repo quando o
# commit acontece dentro dele. Mesmo formato do wiring do Nyx-Code acima.
# Outros projetos passam direto (zero impacto). Backup do hook anterior em
# pre-commit.bak-AUDIT-PRECOMMIT-20260611.
_ouro_root="/home/andrefarias/Desenvolvimento/protocolo-ouroboros"
if [ "$_repo_root_wiring" = "$_ouro_root" ]; then
    if [ -f "$_ouro_root/hooks/run_framework.sh" ]; then
        bash "$_ouro_root/hooks/run_framework.sh" || exit $?
    fi
fi

source "$HOME/.config/git/hooks/_lib.sh" 2>/dev/null || true

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
cd "$REPO_ROOT" || exit 0

# [0] Validacao de identidade por contexto (SEMPRE roda)
# Graceful degradation: se _lib.sh nao carregou, usar logica inline
if type _hook_detect_context &>/dev/null; then
    _hook_detect_context "$REPO_ROOT"
    _hook_validate_identity || exit 1
else
    CURRENT_NAME=$(git config --get user.name)
    CURRENT_EMAIL=$(git config --get user.email)

    # Fallback: resolver identidade via variaveis de config.local.zsh
    EXPECTED_NAME=""
    CONTEXT="Pessoal"
    for tag in $ZSH_IDENTITY_TAGS; do
        local path_var="ZSH_IDENTITY_${tag}_PATH"
        local path_pattern="${!path_var}"
        if [[ -n "$path_pattern" && ("$REPO_ROOT" == *"/${path_pattern}/"* || "$REPO_ROOT" == *"/${path_pattern}") ]]; then
            local name_var="ZSH_IDENTITY_${tag}_NAME"
            local email_var="ZSH_IDENTITY_${tag}_EMAIL"
            EXPECTED_NAME="${!name_var}"
            EXPECTED_EMAIL="${!email_var}"
            CONTEXT="$tag"
            break
        fi
    done
    if [[ -z "$EXPECTED_NAME" ]]; then
        EXPECTED_NAME="${ZSH_GIT_NAME_PESSOAL:-$(git config --global user.name)}"
        EXPECTED_EMAIL="${ZSH_GIT_EMAIL_PESSOAL:-$(git config --global user.email)}"
    fi

    if [[ "$CURRENT_NAME" != "$EXPECTED_NAME" || "$CURRENT_EMAIL" != "$EXPECTED_EMAIL" ]]; then
        echo "  [BLOQUEIO] Identidade incorreta para contexto $CONTEXT"
        echo "    Esperado: $EXPECTED_NAME <$EXPECTED_EMAIL>"
        echo "    Atual:    $CURRENT_NAME <$CURRENT_EMAIL>"
        echo "    Corrija com: santuario <projeto>"
        exit 1
    fi
fi

# Detectar se projeto usa framework pre-commit
HAS_FRAMEWORK=false
[ -f ".pre-commit-config.yaml" ] && HAS_FRAMEWORK=true

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
[ -z "$STAGED" ] && exit 0

# Filtrar binarios, venv, lock files, etc.
filter_files() {
    local result=""
    for file in $1; do
        case "$file" in
            venv/*|.venv/*|node_modules/*|__pycache__/*) continue ;;
            .git/*|.mypy_cache/*|.pytest_cache/*|.ruff_cache/*) continue ;;
            hooks/*|.githooks/*|.git/hooks/*) continue ;;
            docs/claude/hooks/*|scripts/auditoria-repos.sh|scripts/universal-sanitizer.py) continue ;;
            scripts/ai_identifier_warn.py) continue ;;
            dist/*|build/*|.next/*|.nuxt/*|.eggs/*) continue ;;
            *.png|*.jpg|*.jpeg|*.gif|*.svg|*.ico|*.bmp|*.webp) continue ;;
            *.mp4|*.mp3|*.wav|*.flac|*.ogg|*.webm) continue ;;
            *.zip|*.tar|*.gz|*.bz2|*.xz|*.7z|*.rar) continue ;;
            *.woff|*.woff2|*.ttf|*.eot|*.otf) continue ;;
            *.pdf|*.doc|*.docx|*.xls|*.xlsx) continue ;;
            *.pyc|*.pyo|*.so|*.dylib|*.dll|*.class) continue ;;
            *.pt|*.onnx|*.safetensors|*.gguf) continue ;;
            *.lock|package-lock.json|yarn.lock|poetry.lock|Pipfile.lock) continue ;;
            *.min.js|*.min.css|*.map) continue ;;
            my-mailmap|.mailmap|.env|.env.*) continue ;;
            *)
                # PFL7560-FIX-EXCEPTION (2026-07-06, autorizado pelo dono):
                # nao aplicar auto-fix (whitespace/sanitizer) em arquivos de
                # config binarios/legacy nao-UTF-8 (ex.: ZYCustom.ini da
                # HiSilicon usa ASCII-estendido/NEL 0x85; o auto-fix cortava
                # ~2.5KB e corrompia o arquivo). Escopo: repo pfl7560, no
                # mesmo estilo dos wirings Nyx-Code/ouroboros/Luna acima.
                if [ "$REPO_ROOT" = "/home/andrefarias/Desktop/pfl7560" ] && [ -f "$file" ]; then
                    # (a) config legacy nao-UTF-8 (ex.: ZYCustom.ini HiSilicon, NEL 0x85)
                    if ! iconv -f UTF-8 -t UTF-8 "$file" >/dev/null 2>&1; then
                        continue
                    fi
                    # (b) artefatos byte-exatos com md5 travado por 'make check': o
                    # whitespace/NBSP e significativo (build.prop.STOCK tem NBSP+espaco na
                    # linha 62; o 'sed s/[[:space:]]*$//' cortava e quebrava o md5 fd8406c4
                    # do backup anti-envenenamento do pfl7560-fix.sh). Idem newline final
                    # em init.bigfish.rc.MOD (byte-exato do device).
                    case "$file" in
                        */artefatos/*.STOCK|*/artefatos/*.MOD|*/artefatos/*.ORIGINAL) continue ;;
                        */artefatos/ZYCustom*|*/artefatos/build.prop*|*/artefatos/perfis/*) continue ;;
                        pendrive-autorun/ZYCustom.ini) continue ;;
                    esac
                fi
                result="$result $file" ;;
        esac
    done
    echo "$result" | xargs 2>/dev/null
}

FILES=$(filter_files "$STAGED")
[ -z "$FILES" ] && exit 0

FIXES=0
BLOCKS=0
FIX_DETAILS=""

# === VERIFICACOES DE ANONIMATO (rodam SEMPRE, mesmo com framework) ===

# [1/6] Anti-emoji (auto-fix + re-stage)
_EMOJI="${EMOJI_RE:-[\x{1F600}-\x{1F64F}\x{1F300}-\x{1F5FF}\x{1F680}-\x{1F6FF}\x{2600}-\x{26FF}\x{2700}-\x{27BF}\x{1F900}-\x{1F9FF}\x{1FA00}-\x{1FA6F}\x{1FA70}-\x{1FAFF}]}"
EMOJI_COUNT=0
for file in $FILES; do
    if [ -f "$file" ] && grep -qP "$_EMOJI" "$file" 2>/dev/null; then
        perl -i -CSD -pe "s/$_EMOJI//g" "$file" 2>/dev/null
        git add "$file" 2>/dev/null
        EMOJI_COUNT=$((EMOJI_COUNT + 1))
    fi
done
[ $EMOJI_COUNT -gt 0 ] && { FIXES=$((FIXES + EMOJI_COUNT)); FIX_DETAILS="$FIX_DETAILS emojis($EMOJI_COUNT)"; }

# [2/6] Co-Authored-By em arquivos staged (auto-fix + re-stage)
_COAUTHOR="${COAUTHOR_RE:-[Cc]o-[Aa]uthored-[Bb]y|[Pp]aired-[Ww]ith|[Aa]ssisted-[Bb]y}"
COAUTHOR_COUNT=0
for file in $FILES; do
    if [ -f "$file" ] && grep -qiE "$_COAUTHOR" "$file" 2>/dev/null; then
        grep -viE "$_COAUTHOR" "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
        git add "$file" 2>/dev/null
        COAUTHOR_COUNT=$((COAUTHOR_COUNT + 1))
        _hook_log "pre-commit" "auto-fix co-autoria: $file" 2>/dev/null
    fi
done
[ $COAUTHOR_COUNT -gt 0 ] && { FIXES=$((FIXES + COAUTHOR_COUNT)); FIX_DETAILS="$FIX_DETAILS co-author($COAUTHOR_COUNT)"; }

# [3/6] Mencoes a IA em QUALQUER lugar do conteudo staged -- comentario,
# docstring, prosa, config, model-id (auto-substitui por "agente" + re-stage).
# Ao contrario da versao anterior (so pegava "Generated by X" em linha de
# comentario), casa a palavra em qualquer lugar do arquivo. "Cursor" fica de
# fora da lista principal (colide com cursor de banco/UI real) e ganha
# checagem propria: se o ARQUIVO INTEIRO tiver algum marcador de contexto de
# banco/UI (mesmo filtro do auditoria-repos.sh), pula substituicao de
# "cursor" no arquivo todo -- filtro por linha nao basta, pois a variavel
# `cursor` costuma ser atribuida numa linha e usada (`cursor.execute(...)`)
# em linhas seguintes sem nenhum marcador por perto.
_AI_WORD_CODE="${AI_WORD_CODE_RE:-\\b([Cc]laude|[Aa]nthropic|[Oo]pen[Aa][Ii]|[Cc]hat[Gg][Pp][Tt]|[Gg]emini|[Gg][Pp][Tt]-[34]|[Dd]eep[Ss]eek|[Aa]ider|[Ww]indsurf|[Cc]odeium|[Tt]abnine|[Oo]pus|[Ss]onnet|[Hh]aiku|[Ff]able)\\b}"
_AI_CURSOR_EXCLUDE="${AI_CURSOR_EXCLUDE_RE:-(api_key|api-key|provider|model|client|_MODEL|_API|endpoint|baseurl|base_url|\\.cursor\\(\\)|cursor\\s*=\\s*conn|cursor\\s*=\\s*db|cursor\\s*=\\s*self|getcursor|set_cursor|cursor_factory|CursorKind)}"
AI_COUNT=0
for file in $FILES; do
    if [ -f "$file" ]; then
        BEFORE_SUM=$(md5sum "$file" 2>/dev/null | cut -d' ' -f1)
        perl -CSD -i -pe "s/$_AI_WORD_CODE/agente/gi" "$file" 2>/dev/null
        if ! grep -qiP "$_AI_CURSOR_EXCLUDE" "$file" 2>/dev/null; then
            perl -CSD -i -pe "s/\\b[Cc]ursor\\b/agente/g" "$file" 2>/dev/null
        fi
        perl -CSD -i -pe 's/\bagente([\s-]+agente\b)+/agente/gi' "$file" 2>/dev/null
        AFTER_SUM=$(md5sum "$file" 2>/dev/null | cut -d' ' -f1)
        if [ "$BEFORE_SUM" != "$AFTER_SUM" ]; then
            git add "$file" 2>/dev/null
            AI_COUNT=$((AI_COUNT + 1))
            _hook_log "pre-commit" "auto-fix mencao IA (substituicao): $file" 2>/dev/null
        fi
    fi
done
[ $AI_COUNT -gt 0 ] && { FIXES=$((FIXES + AI_COUNT)); FIX_DETAILS="$FIX_DETAILS ia-artifact($AI_COUNT)"; }

# [3.5/6] Anti-blacklist filenames: bloqueia ADICAO ao tracking de
# arquivos de instrucao para IA (CLAUDE.md, HANDOFF, .cursorrules, etc).
# Lista canonica em ~/.config/git/anonymity-blacklist.txt.
BLACKLIST="$HOME/.config/git/anonymity-blacklist.txt"
if [ -f "$BLACKLIST" ]; then
    ADDED=$(git diff --cached --name-only --diff-filter=A 2>/dev/null)
    if [ -n "$ADDED" ]; then
        BLOCKED_FILES=""
        while IFS= read -r pattern; do
            [ -z "$pattern" ] && continue
            [[ "$pattern" =~ ^# ]] && continue
            clean="${pattern%/}"
            for f in $ADDED; do
                case "$f" in
                    $clean|$clean/*) BLOCKED_FILES="$BLOCKED_FILES $f" ;;
                esac
            done
        done < "$BLACKLIST"
        if [ -n "$BLOCKED_FILES" ]; then
            echo "  [BLOQUEIO] Arquivos da blacklist anonimato no diff:"
            for f in $BLOCKED_FILES; do echo "    $f"; done
            echo ""
            echo "    Estes arquivos sao instrucao para IA e nao devem"
            echo "    ser versionados (Regra -1, anonimato absoluto)."
            echo ""
            echo "    Para remover do staging mantendo no filesystem:"
            echo "      git rm --cached$BLOCKED_FILES"
            echo "      printf '%s\n'$BLOCKED_FILES >> .gitignore"
            _hook_log "pre-commit" "BLOQUEADO: blacklist filename ($BLOCKED_FILES)" 2>/dev/null
            exit 1
        fi
    fi
fi

# === VERIFICACOES ADICIONAIS (puladas se framework pre-commit existe) ===

if [[ "$HAS_FRAMEWORK" == false ]]; then

    # [4/6] Whitespace: trailing spaces + newline final (auto-fix + re-stage)
    WS_COUNT=0
    for file in $FILES; do
        if [ -f "$file" ]; then
            CHANGED=0
            if grep -qP '[\t ]+$' "$file" 2>/dev/null; then
                sed -i 's/[[:space:]]*$//' "$file"
                CHANGED=1
            fi
            if [ -n "$(tail -c 1 "$file" 2>/dev/null)" ]; then
                echo "" >> "$file"
                CHANGED=1
            fi
            if [ $CHANGED -eq 1 ]; then
                git add "$file" 2>/dev/null
                WS_COUNT=$((WS_COUNT + 1))
            fi
        fi
    done
    [ $WS_COUNT -gt 0 ] && { FIXES=$((FIXES + WS_COUNT)); FIX_DETAILS="$FIX_DETAILS whitespace($WS_COUNT)"; }

    # [5/6] Secrets (BLOQUEIA - nao tem auto-fix seguro)
    _SECRET="${SECRET_RE:-sk-[a-zA-Z0-9]{20,}}"
    for file in $FILES; do
        case "$file" in
            .env|.env.*|*.key|*.pem|*.cert|*.crt) continue ;;
        esac
        if [ -f "$file" ] && grep -qP "$_SECRET" "$file" 2>/dev/null; then
            echo "  [BLOQUEIO] Secret detectado: $file"
            BLOCKS=$((BLOCKS + 1))
        fi
    done

    # [6/6] Python: syntax check (BLOQUEIA)
    for file in $FILES; do
        case "$file" in
            *.py)
                if [ -f "$file" ] && ! python3 -m py_compile "$file" 2>/dev/null; then
                    echo "  [BLOQUEIO] Sintaxe invalida: $file"
                    BLOCKS=$((BLOCKS + 1))
                fi
                ;;
        esac
    done

fi

# === VERIFICACOES UNIVERSAIS (avisos, rodam SEMPRE, mesmo com framework) ===

WARNINGS=0

# [7] Acentuacao PT-BR (auto-fix real via validar-acentuacao.py --fix, re-stage)
VALIDADOR_ACENTO="$HOME/.config/zsh/scripts/validar-acentuacao.py"
ACCENT_TARGETS=""
for file in $FILES; do
    case "$file" in
        *.md|*.py|*.zsh|*.sh|*.txt|*.rst) [ -f "$file" ] && ACCENT_TARGETS="$ACCENT_TARGETS $file" ;;
    esac
done
if [ -n "$ACCENT_TARGETS" ] && [ -f "$VALIDADOR_ACENTO" ] && command -v python3 &>/dev/null; then
    python3 "$VALIDADOR_ACENTO" --fix --paths $ACCENT_TARGETS >/dev/null 2>&1
    ACCENT_COUNT=0
    for file in $ACCENT_TARGETS; do
        git add "$file" 2>/dev/null && ACCENT_COUNT=$((ACCENT_COUNT + 1))
    done
    [ $ACCENT_COUNT -gt 0 ] && { FIXES=$((FIXES + ACCENT_COUNT)); FIX_DETAILS="$FIX_DETAILS acentuacao($ACCENT_COUNT)"; }
fi

# [8] Hardcoded paths absolutos (AVISO)
HARDCODED_COUNT=0
for file in $FILES; do
    case "$file" in
        *.py|*.sh|*.bash|*.zsh|*.js|*.ts)
            if [ -f "$file" ] && grep -qE '(/home/[a-zA-Z0-9_-]+/|/Users/[a-zA-Z0-9_-]+/)' "$file" 2>/dev/null; then
                HARDCODED_COUNT=$((HARDCODED_COUNT + 1))
                if [ $HARDCODED_COUNT -le 3 ]; then
                    echo "  [aviso] Path absoluto hardcoded: $file"
                fi
            fi
            ;;
    esac
done
[ $HARDCODED_COUNT -gt 0 ] && WARNINGS=$((WARNINGS + HARDCODED_COUNT))

# [9] Debug statements: print() / console.log() (AVISO)
DEBUG_COUNT=0
for file in $FILES; do
    case "$file" in
        *.py)
            if [ -f "$file" ] && grep -qE '^\s*print\(' "$file" 2>/dev/null; then
                DEBUG_COUNT=$((DEBUG_COUNT + 1))
                if [ $DEBUG_COUNT -le 3 ]; then
                    echo "  [aviso] print() detectado: $file (usar logging)"
                fi
            fi
            ;;
        *.js|*.ts|*.jsx|*.tsx)
            if [ -f "$file" ] && grep -qE '^\s*console\.(log|debug|info|warn)\(' "$file" 2>/dev/null; then
                DEBUG_COUNT=$((DEBUG_COUNT + 1))
                if [ $DEBUG_COUNT -le 3 ]; then
                    echo "  [aviso] console.log detectado: $file"
                fi
            fi
            ;;
    esac
done
[ $DEBUG_COUNT -gt 0 ] && WARNINGS=$((WARNINGS + DEBUG_COUNT))

# [10] Arquivo grande >5MB staged (AVISO)
for file in $STAGED; do
    if [ -f "$file" ]; then
        SIZE=$(stat --format="%s" "$file" 2>/dev/null || stat -f "%z" "$file" 2>/dev/null)
        if [ -n "$SIZE" ] && [ "$SIZE" -gt 5242880 ] 2>/dev/null; then
            SIZE_MB=$((SIZE / 1048576))
            echo "  [aviso] Arquivo grande (${SIZE_MB}MB): $file"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

# Chamar universal-sanitizer.py como camada adicional (se Python disponivel)
if command -v python3 &>/dev/null; then
    SANITIZER="$HOME/.config/zsh/scripts/universal-sanitizer.py"
    if [ -f "$SANITIZER" ]; then
        python3 "$SANITIZER" $FILES 2>/dev/null
        # Re-stage arquivos que o sanitizer pode ter modificado
        for file in $FILES; do
            [ -f "$file" ] && git add "$file" 2>/dev/null
        done
    fi
fi

# Nome de fornecedor de IA colado em identificador (snake_case, ex:
# claude_gemini_opus) -- \b de regex nao separa por underscore, entao o
# scanner amplo do [3/6] nao pega. Primeira vez: so avisa. Se o mesmo
# identificador aparecer staged de novo numa proxima tentativa: substitui.
if command -v python3 &>/dev/null; then
    ID_WARN="$HOME/.config/zsh/scripts/ai_identifier_warn.py"
    if [ -f "$ID_WARN" ]; then
        python3 "$ID_WARN" $FILES 2>/dev/null
        for file in $FILES; do
            [ -f "$file" ] && git add "$file" 2>/dev/null
        done
    fi
fi

# Relatorio
if [ $FIXES -gt 0 ]; then
    echo "  [auto-fix]$FIX_DETAILS -> re-staged"
    _hook_log "pre-commit" "auto-fix:$FIX_DETAILS" 2>/dev/null
fi

if [ $BLOCKS -gt 0 ]; then
    echo "  [pre-commit] $BLOCKS problemas bloqueantes. Corrija antes de commitar."
    _hook_log "pre-commit" "BLOQUEADO ($BLOCKS problemas)" 2>/dev/null
    exit 1
fi

# HOOK-POSTCOMMIT-CHAIN-01 (Leva 4.1 Luna, 2026-06-12, autorizado pelo dono):
# delega ao framework pre-commit do repo Luna (66 hooks T1-T4) DEPOIS dos
# auto-fixes globais de anonimato -- o framework valida o resultado ja
# corrigido. Mesmo formato dos wirings Nyx-Code/ouroboros acima. Outros
# repos: zero impacto.
_luna_root_wiring="/home/andrefarias/Desenvolvimento/Luna"
if [ "$REPO_ROOT" = "$_luna_root_wiring" ] && [ -x "$_luna_root_wiring/.git/hooks/pre-commit" ]; then
    bash "$_luna_root_wiring/.git/hooks/pre-commit" || exit $?
fi

_hook_log "pre-commit" "OK (fixes=$FIXES)" 2>/dev/null
exit 0

# "Quem vigia os vigilantes?" — Juvenal
