#!/bin/bash
# .zsh_secrets — Shim que carrega config.local.zsh (identidades/caminhos), com
# vault/secrets.gpg (AES256 simétrica) como backup cifrado para o repo.
#
# Ordem de resolução (1ª que funcionar vence):
#   0. config.local.zsh no disco (gitignored) — sourceia DIRETO, sem GPG. Caso normal.
#   Fallback (só se config.local.zsh não existe — máquina nova antes do install.sh):
#   1. gpg-agent cache (TTL 30 dias) — silencioso
#   2. ~/.local/state/zsh-vault-passphrase (chmod 600, fora do repo) — silencioso
#   3. Pinentry interativo (TTY) — pede manualmente
#
# Modelo de ameaça:
#   - Repo publicado: vault cifrado, atacante NÃO tem passphrase (passphrase fora do repo)
#   - Acesso local como user: equivalente a .zsh_secrets plaintext (qualquer processo do user lê)
#
# Para mudar para modo "máxima segurança / digite por boot":
#   rm ~/.local/state/zsh-vault-passphrase
#   (shim volta ao fluxo gpg-agent + pinentry)
#
# Para re-cifrar com passphrase nova:
#   gpg -d vault/secrets.gpg | gpg --symmetric --cipher-algo AES256 -o vault/secrets.new.gpg
#   mv vault/secrets.new.gpg vault/secrets.gpg
#   echo 'nova-passphrase' > ~/.local/state/zsh-vault-passphrase
#   chmod 600 ~/.local/state/zsh-vault-passphrase

_config_local="${ZDOTDIR:-$HOME/.config/zsh}/config.local.zsh"
_vault="${ZDOTDIR:-$HOME/.config/zsh}/vault/secrets.gpg"
_passfile="$HOME/.local/state/zsh-vault-passphrase"

if [ -f "$_config_local" ]; then
    # Caso normal (dia a dia): a fonte da verdade é o arquivo local, gitignored.
    # Sourceia direto — SEM GPG, sem risco de pinentry, sem drift (o cofre não fica
    # velho em relação ao arquivo). vault/secrets.gpg é só backup/fallback.
    source "$_config_local"
elif [ -f "$_vault" ]; then
    # Fallback: config.local.zsh ainda não existe (máquina nova, antes do install.sh
    # restaurar). Decifra o cofre — que é exatamente gpg(config.local.zsh).
    # 1ª tentativa: gpg-agent cache. --pinentry-mode error: cache frio falha em silêncio.
    _secrets=$(gpg --decrypt --quiet --batch --pinentry-mode error "$_vault" 2>/dev/null)

    # 2ª tentativa: passphrase-file. --pinentry-mode loopback: usa a file direto (gpg 2.x
    # ignora --passphrase-file sem loopback e cai no agent/pinentry).
    if [ -z "$_secrets" ] && [ -f "$_passfile" ]; then
        _secrets=$(gpg --decrypt --quiet --batch --pinentry-mode loopback --passphrase-file "$_passfile" "$_vault" 2>/dev/null)
    fi

    # 3ª tentativa: pinentry interativo (TTY).
    if [ -z "$_secrets" ] && [ -t 0 ] && [ -t 1 ]; then
        _secrets=$(gpg --decrypt --quiet "$_vault" 2>/dev/null)
    fi

    if [ -n "$_secrets" ]; then
        eval "$_secrets"
    else
        echo "[secrets] vault travado. Destrave com: gpg --decrypt $_vault >/dev/null" >&2
    fi
fi

unset _secrets _vault _passfile _config_local
