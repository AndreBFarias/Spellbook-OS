#!/bin/bash
# Aurora 2.0 - Root tunings (idempotente, logs no journalctl)
# Invocado por aurora-root.service e aurora-watchdog.service
set -u

log() { printf '[aurora-root] %s\n' "$*"; }
warn() { printf '[aurora-root][WARN] %s\n' "$*" >&2; }

ALVO_GOVERNOR="powersave"   # Aurora 2.6: governor dinâmico (downclock em idle, turbo sob carga via EPP+boost)
ALVO_EPP="performance"
SYSCTL_FILE="/etc/sysctl.d/99-aurora.conf"

# 1. system76-power profile performance (idempotente)
if command -v system76-power >/dev/null 2>&1; then
  atual=$(system76-power profile 2>/dev/null | awk -F': ' '/Power Profile/ {print tolower($2)}')
  if [ "$atual" = "performance" ]; then
    log "system76-power ja em performance"
  else
    if system76-power profile performance 2>&1; then
      log "system76-power -> performance (era: ${atual:-?})"
    else
      warn "system76-power profile performance falhou"
    fi
  fi
else
  warn "system76-power nao instalado"
fi

# 2. CPU governor para todos os cores
desviou=0
for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
  cur=$(cat "$gov" 2>/dev/null) || continue
  if [ "$cur" != "$ALVO_GOVERNOR" ]; then
    if echo "$ALVO_GOVERNOR" > "$gov" 2>/dev/null; then
      desviou=$((desviou + 1))
    else
      warn "falha escrevendo $gov"
    fi
  fi
done
[ $desviou -gt 0 ] && log "governor: $desviou cores ajustados para $ALVO_GOVERNOR" || log "governor: ja em $ALVO_GOVERNOR"

# 3. Energy Performance Preference (amd_pstate)
desviou=0
for epp in /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference; do
  [ -f "$epp" ] || continue
  cur=$(cat "$epp" 2>/dev/null) || continue
  if [ "$cur" != "$ALVO_EPP" ]; then
    if echo "$ALVO_EPP" > "$epp" 2>/dev/null; then
      desviou=$((desviou + 1))
    fi
  fi
done
[ $desviou -gt 0 ] && log "EPP: $desviou cores ajustados para $ALVO_EPP" || log "EPP: ja em $ALVO_EPP"

# 4. earlyoom
if systemctl is-enabled earlyoom.service >/dev/null 2>&1; then
  log "earlyoom ja enabled"
else
  systemctl enable earlyoom.service >/dev/null 2>&1 && log "earlyoom enabled"
fi
if systemctl is-active earlyoom.service >/dev/null 2>&1; then
  log "earlyoom ja active"
else
  systemctl start earlyoom.service && log "earlyoom started" || warn "earlyoom start falhou"
fi

# 5. sysctl
if [ -f "$SYSCTL_FILE" ]; then
  if sysctl -p "$SYSCTL_FILE" >/dev/null 2>&1; then
    log "sysctl aplicado: $SYSCTL_FILE"
  else
    warn "sysctl -p falhou em $SYSCTL_FILE"
  fi
else
  warn "$SYSCTL_FILE nao existe"
fi

# 6. Aurora 2.6 - suspend REABILITADO (laptop-friendly). Desfaz o mask anterior.
SLEEP_TARGETS=(sleep.target suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target)
unmasked=0
for t in "${SLEEP_TARGETS[@]}"; do
  state=$(systemctl is-enabled "$t" 2>/dev/null || true)
  if [ "$state" = "masked" ]; then
    systemctl unmask "$t" >/dev/null 2>&1 && unmasked=$((unmasked + 1))
  fi
done
[ $unmasked -gt 0 ] && log "suspend reabilitado: $unmasked targets desmascarados" || log "suspend: targets ja livres"

# 7. Aurora 2.6 - CPU livre p/ downclock em idle (scaling_min = mínimo de hardware).
# Desfaz o pin min=max; reduz calor/consumo parado. Boost (seção 8) + governor
# dinâmico preservam performance total sob carga.
unpinned=0
for cpu in /sys/devices/system/cpu/cpu*/cpufreq; do
  [ -d "$cpu" ] || continue
  hwmin=$(cat "$cpu/cpuinfo_min_freq" 2>/dev/null) || continue
  min=$(cat "$cpu/scaling_min_freq" 2>/dev/null) || continue
  if [ "$min" != "$hwmin" ]; then
    if echo "$hwmin" > "$cpu/scaling_min_freq" 2>/dev/null; then
      unpinned=$((unpinned + 1))
    fi
  fi
done
[ $unpinned -gt 0 ] && log "CPU liberado: $unpinned cores scaling_min=hw_min" || log "CPU: scaling_min ja no minimo"

# 8. Aurora 2.3 ULTRA - boost CPU = 1 (idempotente)
if [ -f /sys/devices/system/cpu/cpufreq/boost ]; then
  cur=$(cat /sys/devices/system/cpu/cpufreq/boost)
  if [ "$cur" != "1" ]; then
    echo 1 > /sys/devices/system/cpu/cpufreq/boost 2>/dev/null && log "boost CPU -> 1" || warn "boost write falhou"
  else
    log "boost CPU ja em 1"
  fi
fi

# 9. Aurora 2.3 ULTRA - NVIDIA persistence mode (idempotente)
if command -v nvidia-smi >/dev/null 2>&1; then
  pm=$(nvidia-smi --query-gpu=persistence_mode --format=csv,noheader 2>/dev/null | head -1 | tr '[:upper:]' '[:lower:]')
  if [ "$pm" != "enabled" ]; then
    nvidia-smi -pm 1 >/dev/null 2>&1 && log "NVIDIA persistence-mode -> Enabled" || warn "nvidia-smi -pm 1 falhou"
  else
    log "NVIDIA persistence-mode ja Enabled"
  fi
fi

# 10. Aurora 2.3 ULTRA - garante que default-wifi-powersave-on.conf nao volte
# (sobrescreve nosso 99-aurora-ultra-wifi.conf por ordem alfabetica: 9 < d em ASCII)
if [ -f /etc/NetworkManager/conf.d/default-wifi-powersave-on.conf ]; then
  mv /etc/NetworkManager/conf.d/default-wifi-powersave-on.conf \
     /etc/NetworkManager/conf.d/default-wifi-powersave-on.conf.bak-aurora-ultra
  systemctl reload NetworkManager 2>/dev/null || true
  log "default-wifi-powersave-on.conf removido (sobrescrevia powersave=2)"
fi

log "aurora-root-apply concluido"
exit 0
