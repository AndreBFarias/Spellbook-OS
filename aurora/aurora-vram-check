#!/bin/bash
# Aurora 2.1 - VRAM watchdog
# Se VRAM total >= 90% E ollama é o maior consumidor, reinicia ollama.service
# (libera VRAM sem matar processo do usuário; ollama respawn carrega lazy)
set -u
THRESHOLD_PCT=90
LOG_TAG="aurora-vram-watchdog"

log() { logger -t "$LOG_TAG" "$*"; }

command -v nvidia-smi >/dev/null 2>&1 || { log "nvidia-smi ausente"; exit 0; }

read -r used total < <(nvidia-smi --query-gpu=memory.used,memory.total \
    --format=csv,noheader,nounits 2>/dev/null | tr ',' ' ' | head -1)
[ -z "${used:-}" ] && exit 0
[ -z "${total:-}" ] && exit 0
[ "$total" -le 0 ] && exit 0

pct=$(( used * 100 / total ))
[ "$pct" -lt "$THRESHOLD_PCT" ] && exit 0

log "ALERTA: VRAM=${pct}% (${used}/${total} MiB)"

# Identifica top consumer
top_proc=$(nvidia-smi --query-compute-apps=pid,process_name,used_memory \
    --format=csv,noheader,nounits 2>/dev/null | sort -t',' -k3 -n -r | head -1)

if [ -z "$top_proc" ]; then
  log "Nenhum compute app reportado por nvidia-smi — sem ação"
  exit 0
fi

if echo "$top_proc" | grep -qE 'ollama|llama_server'; then
  log "Top consumer é ollama: ${top_proc} — reiniciando ollama.service"
  if systemctl restart ollama.service; then
    log "ollama.service reiniciado com sucesso"
  else
    log "FALHA ao reiniciar ollama.service"
  fi
else
  log "Top consumer não é ollama: ${top_proc} — sem ação automática"
fi
exit 0
