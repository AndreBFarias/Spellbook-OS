# .zsh_secrets.template — Template para tokens e API keys
#
# Arquitetura atual (vault GPG cifrado + passphrase em arquivo separado):
#
#   ~/.config/zsh/.zsh_secrets        -> shim que decifra (versionado como shim)
#   ~/.config/zsh/vault/secrets.gpg   -> tokens cifrados AES256 (versionado, commitável)
#   ~/.local/state/zsh-vault-passphrase -> passphrase em texto (chmod 600, fora do repo)
#   ~/.gnupg/gpg-agent.conf           -> default-cache-ttl 2592000 (30 dias)
#
# Setup novo (em outra máquina ou recovery):
#   1. Preencha os exports abaixo com seus tokens, salve como .zsh_secrets.plaintext
#   2. Cifre:
#        gpg --symmetric --cipher-algo AES256 -o vault/secrets.gpg .zsh_secrets.plaintext
#      (será pedida a passphrase 2x)
#   3. Salve a passphrase fora do repo:
#        echo 'SUA-PASSPHRASE' > ~/.local/state/zsh-vault-passphrase
#        chmod 600 ~/.local/state/zsh-vault-passphrase
#   4. Apague .zsh_secrets.plaintext (não precisa mais; backup já está cifrado).
#   5. Configure gpg-agent TTL longo:
#        mkdir -p ~/.gnupg && chmod 700 ~/.gnupg
#        cat > ~/.gnupg/gpg-agent.conf <<'EOF'
#        default-cache-ttl 2592000
#        max-cache-ttl 2592000
#        pinentry-program /usr/bin/pinentry
#        EOF
#        gpgconf --reload gpg-agent
#   6. Validar: source ~/.config/zsh/.zsh_secrets && echo "${GIT_TOKEN_PESSOAL:0:7}"
#      Deve printar "ghp_..." (ou prefixo equivalente).
#
# Setup simplificado (sem vault — apenas plaintext gitignored, modo "antigo"):
#   1. cp .zsh_secrets.template .zsh_secrets
#   2. chmod 600 .zsh_secrets
#   3. Editar e preencher os exports abaixo.
#   4. Substituir o shim em .zsh_secrets pelos exports diretamente.

# GitHub Personal Access Tokens
export GIT_TOKEN_PESSOAL=""
export GIT_TOKEN_MEC=""
export GIT_TOKEN_VIT=""
export GIT_PESSOAL_VIT=""

# Google / Gemini
export GEMINI_API_KEY=""
export GEMINI_MODEL=""

# Anthropic
export ANTHROPIC_API_KEY=""

# DeepSeek
export DEEPSEEK_API_KEY=""

# Hugging Face
export HUGGING_FACE_HUB_TOKEN=""

# Aider
export AIDER_NO_AUTO_COMMITS=1
export AIDER_SHOW_DIFFS=1
