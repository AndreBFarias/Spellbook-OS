# .zsh_secrets.template — Template para tokens e API keys
#
# Setup recomendado (com vault GPG):
#   1. Preencha este arquivo com seus tokens e salve como `.zsh_secrets.plaintext`
#   2. Cifre:
#        gpg --symmetric --cipher-algo AES256 --output vault/secrets.gpg .zsh_secrets.plaintext
#   3. Copie o shim (já versionado em .zsh_secrets) — ele decifra via gpg-agent.
#   4. Apague .zsh_secrets.plaintext (após validar `source .zsh_secrets`).
#   5. Configure gpg-agent TTL em ~/.gnupg/gpg-agent.conf:
#        default-cache-ttl 14400
#        max-cache-ttl 28800
#
# Setup simplificado (sem vault — apenas plaintext gitignored):
#   1. cp .zsh_secrets.template .zsh_secrets
#   2. chmod 600 .zsh_secrets
#   3. Editar e preencher os exports abaixo.
#   4. Substituir o shim em .zsh_secrets pelos exports diretamente.

# GitHub Personal Access Tokens
export GIT_TOKEN_PESSOAL=""
export GIT_TOKEN_MEC=""
export GIT_TOKEN_VIT=""
export GIT_PESSOAL_VIT=""

# Google / Gemini
export GEMINI_API_KEY=""
export GEMINI_MODEL=""

# Anthropic
export ANTHROPIC_API_KEY=""

# DeepSeek
export DEEPSEEK_API_KEY=""

# Hugging Face
export HUGGING_FACE_HUB_TOKEN=""

# Aider
export AIDER_NO_AUTO_COMMITS=1
export AIDER_SHOW_DIFFS=1
